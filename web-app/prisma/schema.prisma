// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  role          String    @default("CLIENT") // "ADMIN" or "CLIENT"
  image         String?
  projects      Project[]
  invoices      Invoice[]
  messages      Message[] @relation("UserMessages")
  adminMessages Message[] @relation("AdminMessages")
  posts         Post[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("PLANNING") // "IN_PROGRESS", "COMPLETED", etc.
  progress    Int      @default(0) // 0 to 100
  clientId    String
  client      User     @relation(fields: [clientId], references: [id])
  invoices    Invoice[]
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invoice {
  id          String   @id @default(cuid())
  amount      Float
  status      String   @default("UNPAID") // "PAID", "OVERDUE"
  pdfUrl      String?
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  clientId    String
  client      User     @relation(fields: [clientId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id          String   @id @default(cuid())
  content     String
  senderId    String
  sender      User     @relation("UserMessages", fields: [senderId], references: [id])
  adminId     String?
  admin       User?    @relation("AdminMessages", fields: [adminId], references: [id])
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteMetric {
  id    String @id @default("global")
  views Int    @default(0)
}

model DailyMetric {
  id    String @id @default(cuid())
  date  String @unique
  views Int    @default(0)
}
